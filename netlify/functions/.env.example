# ============================================================
# SNAPIBABY — Variáveis de Ambiente para Netlify
# Configure em: Netlify Dashboard → Site settings → Environment variables
# NUNCA commite este arquivo com valores reais!
# ============================================================

# ── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://ellkwqmnidcimosllccv.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<cole aqui a service_role key do Supabase → Settings → API>

# ── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...        # ou sk_test_... para testes
STRIPE_WEBHOOK_SECRET=whsec_...      # gerado ao criar o webhook no Stripe Dashboard

# ── KIE AI (geração de imagens) ─────────────────────────────
KIE_API_KEY=<cole aqui sua chave do KIE AI → app.kie.ai → API Keys>

# ── Resend (email de entrega das fotos) ─────────────────────
RESEND_API_KEY=re_...   # resend.com/api-keys → Create API Key

# ============================================================
# Onde pegar cada chave:
#
# SUPABASE_SERVICE_ROLE_KEY:
#   supabase.com/dashboard → Snapibaby 01 → Settings → API
#   (seção "Project API keys" → "service_role" — NÃO é a anon key!)
#
# STRIPE_SECRET_KEY:
#   dashboard.stripe.com → Developers → API keys → Secret key
#
# STRIPE_WEBHOOK_SECRET:
#   dashboard.stripe.com → Developers → Webhooks → Add endpoint
#   URL: https://SEU-SITE.netlify.app/.netlify/functions/stripe-webhook
#   Evento: payment_intent.succeeded
#   Copie o "Signing secret" gerado
#
# KIE_API_KEY:
#   app.kie.ai → Account → API Keys → Create new key
#   Autenticação: Bearer token no header Authorization
# ============================================================
